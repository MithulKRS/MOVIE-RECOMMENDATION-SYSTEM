import pandas as pd
import numpy as np


data=pd.read_csv("tmdb_5000_movies.csv")
c_data=pd.read_csv("tmdb_5000_credits.csv")


data.head()


c_data.head()


data=data.merge(c_data,on='title')


data.head(1)


#genre
